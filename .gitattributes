# Enforce LF line endings for source files regardless of client OS.
# Prevents gofmt/black failing on Linux CI after a Windows commit.

* text=auto

*.go        text eol=lf
*.py        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.service   text eol=lf
*.conf      text eol=lf
*.sh        text eol=lf
Dockerfile  text eol=lf

# Windows-native files keep CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary — never touch
*.png  binary
*.jpg  binary
